      'select vendas.vendaId,'
      'vendas.ClienteId,'
      'clientes.nome,'
      'vendas.dataVenda,'
      'vendas.totalVenda'
      
        'from vendas inner join clientes on clientes.clienteId = vendas.c' +
        'lienteId'
