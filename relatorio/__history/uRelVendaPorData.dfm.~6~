  object QryVenda: TFDQuery
    Active = True
    Connection = dtmConexao.dtmPrincipal
    SQL.Strings = (
      'SELECT vendas.vendaId,'
      '       vendas.clienteId,'
      '       clientes.nome,'
      '       vendas.dataVenda,'
      '       cast(vendas.totalVenda as numeric(18,3)) as totalVenda'
      'from vendas'
      '    inner join clientes on clientes.clienteId = vendas.clienteId'
      '    where vendas.dataVenda BETWEEN :DataInicio and :DataFim'
      '    order by vendas.dataVenda, vendas.clienteId')
    Left = 512
    Top = 384
    ParamData = <
      item
        Name = 'DataInicio'
        DataType = ftDate
        ParamType = ptInput
        Value = 46082d
      end
      item
        Name = 'DataFim'
        DataType = ftDate
        ParamType = ptInput
        Value = 46112d
      end>
