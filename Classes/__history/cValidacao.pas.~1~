  // 5. O VEREDITO FINAL:
  // Se o 1ş e o 2ş dígitos que a SUA matemática achou forem EXATAMENTE IGUAIS
  // aos 2 últimos números que o usuário digitou na tela, entăo o CPF é verdadeiro.
  if (Dígitos_Calculados = Dígitos_Digitados) then
    Result := True
  else
    Result := False;
end;

