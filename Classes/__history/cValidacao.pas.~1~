var
  CPF_Limpo: string;
  // Aqui vocę declararia as variáveis de laço (I, Soma, Resto, Digito1, Digito2)
begin
  // 1. TIRAR A SUJEIRA:
  // O usuário pode digitar '123.456.789-00'. O cálculo só aceita números.
  // Use a funçăo StringReplace para trocar '.' e '-' por nada ('').
  CPF_Limpo := // lógica de limpeza...

  // 2. BARRAR OS ENGRAÇADINHOS (Filtro Básico):
  // Se o CPF_Limpo năo tiver exatamente 11 caracteres, ou se for uma
  // sequęncia de números iguais (tipo '11111111111' que passa no cálculo mas é falso),
  // a funçăo já chuta a porta e retorna False direto.
  if (Length(CPF_Limpo) <> 11) or (CPF_Limpo = '00000000000') {.. e os outros ..} then
