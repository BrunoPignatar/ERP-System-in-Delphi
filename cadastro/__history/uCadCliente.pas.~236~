procedure TfrmCadCliente.edtDocChange(Sender: TObject);
begin
  inherited;
  if edtDoc.Text = 'Fisica' then   begin
    lblDoc.Caption := 'CPF';
    edtDocumento.MaxLength :=14;
  end
  else if edtDoc.Text = 'Juridica' then begin
    lblDoc.Caption := 'CNPJ';
    edtDocumento.MaxLength:=18;
  end;

