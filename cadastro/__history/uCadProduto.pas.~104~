    Text := FormatFloat('R$ ,##0.00', Sender.AsFloat);
end;

procedure TfrmCadProduto.SpeedButton1Click(Sender: TObject);
var
  Msg: string;
begin
  Msg := 'Os produtos que estão com quantidade baixa em estoque:' + sLineBreak + sLineBreak;

  QryListagem.First;
  while not QryListagem.Eof do
  begin
    if QryListagem.FieldByName('quantidade').AsInteger <=
       QryListagem.FieldByName('qntmini').AsInteger then
    begin
      Msg := Msg +
             QryListagem.FieldByName('nome').AsString +
             ' - Qtd: ' + QryListagem.FieldByName('quantidade').AsString + ' Qtd.Minima: ' + QryListagem.FieldByName('qntmini').AsString +
             sLineBreak;
    end;

    QryListagem.Next;
  end;

  ShowMessage(Msg);
end;

