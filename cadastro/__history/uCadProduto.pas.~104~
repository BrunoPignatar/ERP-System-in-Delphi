function TfrmCadProduto.Excluir: Boolean;
begin
  if oProduto.Seleciona(QryListagem.FieldByName('produtoId').AsInteger) then begin
    result:=oProduto.Apagar;
    if Assigned(frmPrincipal) then
      frmPrincipal.AtualizarDashBoard;
  end;
end;


