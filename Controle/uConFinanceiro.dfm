  object QryBalanco: TFDQuery
    Connection = dtmConexao.dtmPrincipal
    SQL.Strings = (
      'select '
      ' (select sum(totalVenda) from vendas) - '
      ' (select sum(valor * quantidade) from produtos) as lucro;')
    Left = 104
    Top = 9
    object QryBalancolucro: TFMTBCDField
      FieldName = 'lucro'
      Origin = 'lucro'
      ReadOnly = True
      Precision = 38
      Size = 5
    end
  end
  object QryQntItens: TFDQuery
    Connection = dtmConexao.dtmPrincipal
    SQL.Strings = (
      'select'
      '    (select sum(quantidade) from produtos) as qntprodutos,'
      '    (select count(vendaId) from vendas) as qntvendas')
    Left = 208
    Top = 9
    object QryQntItensqntprodutos: TFMTBCDField
      FieldName = 'qntprodutos'
      Origin = 'qntprodutos'
      ReadOnly = True
      Precision = 38
      Size = 5
    end
    object QryQntItensqntvendas: TIntegerField
      FieldName = 'qntvendas'
      Origin = 'qntvendas'
      ReadOnly = True
    end
  end
  object QryTotal: TFDQuery
    Connection = dtmConexao.dtmPrincipal
    SQL.Strings = (
      'select '
      
        '    (select sum(valor * quantidade) from produtos) as totalprodu' +
        'to,'
      '    (select sum(totalVenda) from vendas) as totalvendas;')
    Left = 40
    Top = 9
    object QryTotaltotalproduto: TFMTBCDField
      FieldName = 'totalproduto'
      Origin = 'totalproduto'
      ReadOnly = True
      Precision = 38
      Size = 10
    end
    object QryTotaltotalvendas: TFMTBCDField
      FieldName = 'totalvendas'
      Origin = 'totalvendas'
      ReadOnly = True
      Precision = 38
      Size = 5
    end
  end
end
