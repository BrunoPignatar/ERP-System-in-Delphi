procedure TfrmTelaHeranca.FormClose(Sender: TObject; var Action: TCloseAction);
var
  ArquivoINI: TIniFile;
  I: Integer;
  Secao: string;
begin
  ArquivoINI := TIniFile.Create(ExtractFilePath(Application.ExeName) + 'PreferenciasGrid.ini');

  Secao := oUsuarioLogado.nome + '_' + Self.ClassName;

  try
    ArquivoINI.WriteInteger(Secao, 'QtdColunas', dbgrdListagem.Columns.Count);
  for I := 0 to dbgrdListagem.Columns.Count - 1 do
  begin
    ArquivoINI.WriteInteger(
      Secao,
      dbgrdListagem.Columns[I].FieldName + '.Width',
      dbgrdListagem.Columns[I].Width
    );

    ArquivoINI.WriteInteger(
      Secao,
      dbgrdListagem.Columns[I].FieldName + '.Index',
      dbgrdListagem.Columns[I].Index
    );
  end;
end;

  finally
    ArquivoINI.Free;
  end;
end;

procedure TfrmTelaHeranca.FormShow(Sender: TObject);
var
  ArquivoINI: TIniFile;
  I, Posicao: Integer;
  NomeCampo: string;
  Coluna: TColumn;
  Secao: string;
  QtdColunasSalvas: Integer;
  Ordem: TStringList;
begin
  ArquivoINI := TIniFile.Create(ExtractFilePath(Application.ExeName) + 'PreferenciasGrid.ini');

  Secao := oUsuarioLogado.nome + '_' + Self.ClassName;

  Ordem := TStringList.Create;
  try
    dbgrdListagem.Columns.BeginUpdate;
    try
      QtdColunasSalvas := ArquivoINI.ReadInteger(Secao, 'QtdColunas', -1);

      if QtdColunasSalvas = dbgrdListagem.Columns.Count then
      begin
        // largura
        for I := 0 to dbgrdListagem.Columns.Count - 1 do
        begin
          dbgrdListagem.Columns[I].Width :=
            ArquivoINI.ReadInteger(Secao, 'Coluna' + IntToStr(I),
              dbgrdListagem.Columns[I].Width);
        end;

        // monta lista de ordem salva
        for I := 0 to dbgrdListagem.Columns.Count - 1 do
        begin
          NomeCampo := ArquivoINI.ReadString(Secao, 'Ordem' + IntToStr(I), '');
          if NomeCampo <> '' then
            Ordem.Add(NomeCampo);
        end;

        // aplica ordem de forma estável
        for Posicao := 0 to Ordem.Count - 1 do
        begin
          Coluna := GetColumnByFieldName(dbgrdListagem, Ordem[Posicao]);
          if Assigned(Coluna) then
            Coluna.Index := Posicao;
        end;
      end;

    finally
      dbgrdListagem.Columns.EndUpdate;
    end;

  finally
    Ordem.Free;
    ArquivoINI.Free;
  end;

  if (QryListagem.SQL.Text <> EmptyStr) then
  begin
    QryListagem.IndexFieldNames := IndiceAtual;
    ExibirLabelIndice(IndiceAtual, lblIndice);
    SelectOriginal := QryListagem.SQL.Text;
    QryListagem.Open;
  end;

  ControlarIndiceTab(pgcPrincipal, 0);
  DesabilitarEditPK;

  ControlarBotoes(
    btnNovo, btnAlterar, btnCancelar,
    btnGravar, btnApagar,
    btnNavigator, pgcPrincipal, True
  );
end;

