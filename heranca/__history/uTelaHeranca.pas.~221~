  procedure TfrmTelaHeranca.ControlarBotoes(btnNovo, btnAlterar, btnCancelar,
    btnGravar, btnApagar:TBitBtn; Navegador:TDBNavigator; pgcPrincipal:TPageControl;
    Flag:Boolean);
