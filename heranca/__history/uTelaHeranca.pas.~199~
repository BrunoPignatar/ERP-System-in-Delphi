procedure TfrmTelaHeranca.btnAlterarClick(Sender: TObject);
  begin
    if not TUsuarioLogado.TenhoAcesso(oUsuarioLogado.codigo, Self.Name+'_'+TBitBtn(Sender).Name, dtmConexao.dtmPrincipal) then
    begin
      MessageDlg('Usuário: '+oUsuarioLogado.nome +', năo tem permissăo de acesso', mtWarning,[mbOK],0);
      Abort;
    end;

    ControlarBotoes(btnNovo, btnAlterar, btnCancelar, btnGravar, btnApagar,
    btnNavigator, pgcPrincipal, False);
    EstadoDoCadastro:=ecAlterar;

    ControlarIndiceTab(pgcPrincipal, 1);
  end;

  procedure TfrmTelaHeranca.btnApagarClick(Sender: TObject);
  begin
    if not TUsuarioLogado.TenhoAcesso(oUsuarioLogado.codigo, Self.Name+'_'+TBitBtn(Sender).Name, dtmConexao.dtmPrincipal) then
    begin
      MessageDlg('Usuário: '+oUsuarioLogado.nome +', năo tem permissăo de acesso', mtWarning,[mbOK],0);
      Abort;
    end;

    try
        if (Excluir) then begin
          GravarAuditoria('APAGAR', Self.Caption, 'Registro apagado');
            ControlarBotoes(btnNovo, btnAlterar, btnCancelar, btnGravar, btnApagar,
            btnNavigator, pgcPrincipal, True);
            ControlarIndiceTab(pgcPrincipal, 0);
            LimparEdits;
            QryListagem.Refresh;
        end
        else begin
          MessageDlg('Erro na Exclusăo', mtWarning, [mbOK] ,0);
        end;
    finally
       EstadoDoCadastro:=ecNenhum;
    end;
  end;

  procedure TfrmTelaHeranca.btnCancelarClick(Sender: TObject);
  begin
    ControlarBotoes(btnNovo, btnAlterar, btnCancelar, btnGravar, btnApagar,
    btnNavigator, pgcPrincipal, True);
    ControlarIndiceTab(pgcPrincipal, 0);
    EstadoDoCadastro:=ecNenhum;
    LimparEdits;
  end;

  procedure TfrmTelaHeranca.btnFecharClick(Sender: TObject);
